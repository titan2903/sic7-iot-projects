# Environment Configuration for Gas Leak & Fire Early Warning System Dashboard
# Copy this file to .env and update the values

# InfluxDB Configuration
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=gas_monitoring_org
INFLUXDB_BUCKET=sensor_data

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Multiple chat IDs (comma separated) - supports both personal and group chats
# Example: TELEGRAM_CHAT_IDS=388656092,-1002605564694
TELEGRAM_CHAT_IDS=388656092,-1002605564694

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
UPDATE_INTERVAL=2000

# MQTT Configuration (already hardcoded, but can be moved here)
# MQTT_BROKER=103.127.97.247
# MQTT_PORT=1883
# MQTT_USERNAME=cakrawala_mqtt

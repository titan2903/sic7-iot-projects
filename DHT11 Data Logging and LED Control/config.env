# MQTT Configuration File
# Edit these values according to your setup

# WiFi Settings (for ESP32)
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# MQTT Broker Settings
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883

# MQTT Topics
PUB_TOPIC=sic/dibimbing/catalina/titanio-yudista/pub/dht
SUB_TOPIC=sic/dibimbing/catalina/titanio-yudista/sub/led

# Sensor Settings
DHT_PIN=4
LED_PIN=2
READING_INTERVAL=5000

# Device Settings
DEVICE_ID=ESP32_DHT11
CLIENT_ID=ESP32_DHT11_Client